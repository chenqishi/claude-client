# 飞书机器人配置
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxx
# 飞书域名: feishu (国内) 或 lark (海外)
FEISHU_DOMAIN=feishu

# 访问控制（强烈建议配置，留空则允许所有用户，存在安全风险）
# 允许的用户 open_id 列表，逗号分隔（飞书开放平台 -> 用户身份 -> open_id）
FEISHU_ALLOWED_USER_IDS=ou_xxxxxxxxxxxx,ou_yyyyyyyyyyyy
# 允许的群聊 chat_id 列表，逗号分隔（群内发送 /status 可查看）
FEISHU_ALLOWED_CHAT_IDS=oc_xxxxxxxxxxxx
# 企业 tenant_key，留空则不校验租户（飞书开放平台 -> 基本信息 -> 租户 Key）
FEISHU_TENANT_KEY=

# Claude API 配置
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 可选: 使用 Bedrock/Vertex AI
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# 服务器配置
PORT=3000
HOST=0.0.0.0

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 会话配置
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_LENGTH=50
