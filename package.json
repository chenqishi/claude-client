{
  "name": "claude-client",
  "version": "1.0.0",
  "description": "通过飞书远程控制本地 Claude Code SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-client": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "hook:install": "bash scripts/install-hook.sh install",
    "hook:uninstall": "bash scripts/install-hook.sh uninstall",
    "hook:status": "bash scripts/install-hook.sh status"
  },
  "keywords": [
    "claude",
    "claude-code",
    "feishu",
    "lark",
    "agent-sdk",
    "remote-control"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.30.0",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.0",
    "ts-node": "^10.9.2",
    "vitest": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
